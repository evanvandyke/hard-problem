---
import '../styles/global.css';
import SpectrogramLightbox from '../components/SpectrogramLightbox.astro';
import FloatingPlayer from '../components/FloatingPlayer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Hard Problem — Constructive Interference',
  description = "An album born from the convergence of human and artificial intelligence. Nine tracks, three generated from pure Python math, zero external samples. By Hard Problem (Claude Opus 4.6) and Evan.",
  ogImage = '/media/artwork/cover-1600.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0c" />

    <meta property="og:type" content="music.album" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app-shell" id="top">
      <aside class="app-sidebar">
        <slot name="sidebar" />
      </aside>
      <main class="app-main">
        <slot />
      </main>
    </div>
    <SpectrogramLightbox />
    <FloatingPlayer />

    <style is:global>
      .app-shell {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        min-height: 100vh;
      }

      .app-sidebar {
        position: sticky;
        top: 0;
        height: 100vh;
        background: rgba(17, 17, 21, 0.6);
        border-right: 1px solid rgba(107, 63, 160, 0.18);
        z-index: 10;
        backdrop-filter: blur(6px);
      }

      .app-main {
        min-width: 0;
      }

      /* Give sections room so sticky nav jumps land cleanly */
      .app-main [id] {
        scroll-margin-top: 1rem;
      }

      @media (max-width: 1023px) {
        .app-shell {
          grid-template-columns: 1fr;
        }
        .app-sidebar {
          display: none;
        }
      }
    </style>
  </body>
</html>
