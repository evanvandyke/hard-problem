---
import BaseLayout from '../layouts/BaseLayout.astro';
import AlbumSidebar from '../components/AlbumSidebar.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Gatefold from '../components/Gatefold.astro';
import Origin from '../components/Origin.astro';
import PythonTracksSection from '../components/PythonTracksSection.astro';
import LyriaSection from '../components/LyriaSection.astro';
import SparkleSection from '../components/SparkleSection.astro';
import HumanizeSection from '../components/HumanizeSection.astro';
import HowSoundWorks from '../components/HowSoundWorks.astro';
import CodeShowcase from '../components/CodeShowcase.astro';
import Credits from '../components/Credits.astro';
---

<BaseLayout>
  <AlbumSidebar slot="sidebar" />
  <Hero />
  <Manifesto />
  <Gatefold />
  <Origin />
  <PythonTracksSection />
  <HumanizeSection />
  <HowSoundWorks />
  <CodeShowcase />
  <LyriaSection />
  <SparkleSection />
  <Credits />
</BaseLayout>
