    box-shadow: 0 0 10px rgba(240, 192, 64, 0.6);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .battle-ab.is-playing .ab-scrub-head,
  .ab-scrub:hover .ab-scrub-head {
    opacity: 1;
