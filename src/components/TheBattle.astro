  .ab-time {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(228, 224, 212, 0.55);
    font-variant-numeric: tabular-nums;
    min-width: 5.5em;
    text-align: right;
  }

  .ab-audio { display: none; }

  /* ── Round timeline ── */
  .battle-rounds { margin-bottom: 5.5rem; }

  .rounds {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    position: relative;
  }

  .rounds::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: linear-gradient(180deg,
      transparent 0%,
      rgba(107, 63, 160, 0.4) 8%,
      rgba(199, 75, 143, 0.45) 50%,
      rgba(93, 169, 232, 0.4) 92%,
      transparent 100%);
