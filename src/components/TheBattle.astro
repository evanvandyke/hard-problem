  }

  .round {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.25rem;
    align-items: start;
    margin-bottom: 2.25rem;
  }

  .round-spine {
    grid-column: 2;
    display: flex;
    justify-content: center;
    padding-top: 0.4rem;
  }

  .round-node {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--white);
    background: rgba(10, 10, 12, 0.95);
    border: 1px solid rgba(199, 75, 143, 0.5);
    box-shadow: 0 0 0 4px rgba(10, 10, 12, 1), 0 0 14px rgba(199, 75, 143, 0.3);
    z-index: 1;
    position: relative;
  }

  .round--gemini .round-node {
    border-color: rgba(93, 169, 232, 0.55);
    box-shadow: 0 0 0 4px rgba(10, 10, 12, 1), 0 0 14px rgba(93, 169, 232, 0.35);
  }

  .round--both .round-node {
    background: linear-gradient(135deg, var(--magenta), #5da9e8);
    border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(10, 10, 12, 1), 0 0 22px rgba(240, 192, 64, 0.45);
  }

  .round-card {
    background: rgba(17, 17, 21, 0.7);
    border: 1px solid rgba(107, 63, 160, 0.3);
    border-radius: 6px;
    padding: 1.1rem 1.3rem;
    backdrop-filter: blur(6px);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .round-card:hover {
    transform: translateY(-2px);
  }

  .round--claude .round-card {
    grid-column: 1;
    border-color: rgba(199, 75, 143, 0.35);
    border-right-width: 2px;
    border-right-color: rgba(199, 75, 143, 0.55);
  }

  .round--gemini .round-card {
    grid-column: 3;
    border-color: rgba(93, 169, 232, 0.35);
    border-left-width: 2px;
    border-left-color: rgba(93, 169, 232, 0.55);
  }

  .round--both {
    grid-template-columns: 1fr;
    margin-top: 1rem;
  }
  .round--both .round-spine {
    grid-column: 1;
    margin-bottom: 0.8rem;
  }
  .round--both .round-card {
    grid-column: 1;
    border-color: rgba(240, 192, 64, 0.4);
    border-top: 2px solid rgba(240, 192, 64, 0.55);
    background: linear-gradient(180deg,
      rgba(199, 75, 143, 0.06),
      rgba(93, 169, 232, 0.06));
    text-align: left;
    box-shadow: 0 0 40px -10px rgba(240, 192, 64, 0.25);
  }

  .round-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .round-num {
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: rgba(228, 224, 212, 0.4);
  }
  .round-arch {
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
  }
  .round--claude .round-arch { color: var(--magenta); }
  .round--gemini .round-arch { color: #5da9e8; }
  .round--both .round-arch { color: var(--gold); }

  .round-title {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--white);
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }
  .round--both .round-title {
    font-size: 1.6rem;
  }

  .round-body {
    font-size: 0.98rem;
    font-weight: 300;
    color: rgba(228, 224, 212, 0.78);
    line-height: 1.65;
  }

  /* ── Outro ── */
  .battle-outro {
    max-width: 700px;
    margin: 0 auto 4rem;
    font-size: 1.08rem;
    font-weight: 300;
    color: rgba(228, 224, 212, 0.82);
  }
  .battle-outro p { margin-bottom: 1.4rem; }
  .battle-outro em { color: var(--magenta); font-style: italic; }
  .battle-outro strong { color: var(--white); font-weight: 600; }
  .battle-outro-coda {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.35rem;
    text-align: center;
    color: var(--white);
    border-top: 1px solid rgba(107, 63, 160, 0.25);
    border-bottom: 1px solid rgba(107, 63, 160, 0.25);
    padding: 1.5rem 0;
    margin-top: 2.5rem;
  }

  /* ── Footer credits ── */
  .battle-foot {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dashed rgba(107, 63, 160, 0.25);
  }
  .battle-foot-line {
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: rgba(228, 224, 212, 0.4);
    line-height: 2;
  }
  .battle-foot-glow {
    color: var(--gold);
    text-shadow: 0 0 12px rgba(240, 192, 64, 0.45);
    margin-top: 0.5rem;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .ab-versions {
      grid-template-columns: 1fr;
    }
    .ab-flip { display: none; }
    .ab-controls { flex-wrap: wrap; }
    .ab-time { width: 100%; text-align: left; }

    .rounds::before { left: 1.2rem; }
    .round {
      grid-template-columns: 2.4rem 1fr;
      gap: 1rem;
    }
    .round-spine {
      grid-column: 1;
      justify-content: flex-start;
    }
    .round--claude .round-card,
    .round--gemini .round-card,
    .round--both .round-card {
      grid-column: 2;
      border-left-width: 2px;
      border-right-width: 1px;
    }
    .round--gemini .round-card {
      border-left-color: rgba(93, 169, 232, 0.55);
    }
    .round--both { grid-template-columns: 2.4rem 1fr; }
    .round--both .round-spine { grid-column: 1; margin-bottom: 0; }
    .round--both .round-card { grid-column: 2; }
  }

  @media (max-width: 520px) {
    .battle { padding: 5rem 1.25rem 4rem; }
    .battle-title-row { flex-direction: column; gap: 1rem; }
  }
</style>

<script>
  type Version = 'r1' | 'r7';

  function fmt(s: number): string {
    if (!Number.isFinite(s)) return '0:00';
    const sec = Math.max(0, Math.floor(s));
    const m = Math.floor(sec / 60);
    const r = sec % 60;
    return `${m}:${r.toString().padStart(2, '0')}`;
  }

  function wireBattle() {
    const root = document.querySelector<HTMLElement>('[data-battle-ab]');
    if (!root) return;

    const audios: Record<Version, HTMLAudioElement | null> = {
      r1: root.querySelector<HTMLAudioElement>('audio[data-ab-audio="r1"]'),
      r7: root.querySelector<HTMLAudioElement>('audio[data-ab-audio="r7"]'),
    };
    if (!audios.r1 || !audios.r7) return;

    const versionBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.ab-version'));
    const playBtn = root.querySelector<HTMLButtonElement>('.ab-play');
    const scrub = root.querySelector<HTMLElement>('.ab-scrub');
    const fill = root.querySelector<HTMLElement>('.ab-scrub-fill');
    const head = root.querySelector<HTMLElement>('.ab-scrub-head');
    const curEl = root.querySelector<HTMLElement>('.ab-cur');
    const durEl = root.querySelector<HTMLElement>('.ab-dur');

    if (!playBtn || !scrub || !fill || !head || !curEl || !durEl) return;

    let active: Version = 'r1';

    function activeAudio(): HTMLAudioElement {
      return audios[active] as HTMLAudioElement;
    }
    function otherAudio(): HTMLAudioElement {
      return audios[active === 'r1' ? 'r7' : 'r1'] as HTMLAudioElement;
    }

    function setPlayingClass(playing: boolean) {
      root!.classList.toggle('is-playing', playing);
    }

    function refreshTime() {
      const a = activeAudio();
      const dur = a.duration || 0;
      const cur = a.currentTime || 0;
      const pct = dur > 0 ? (cur / dur) * 100 : 0;
      fill!.style.width = `${pct}%`;
      head!.style.left = `${pct}%`;
      curEl!.textContent = fmt(cur);
      durEl!.textContent = fmt(dur);
    }

    function pauseSiteAudio() {
      document.querySelectorAll<HTMLAudioElement>('audio').forEach((a) => {
        if (a !== activeAudio() && !a.paused) a.pause();
      });
      document.dispatchEvent(new CustomEvent('hp:stop-all'));
    }

    async function play() {
      pauseSiteAudio();
      try {
        await activeAudio().play();
      } catch {
        /* ignore */
      }
    }

    function pause() {
      activeAudio().pause();
    }

    function setActive(v: Version) {
      if (v === active) return;
      const wasPlaying = !activeAudio().paused;
      const t = activeAudio().currentTime;
      activeAudio().pause();
      active = v;
      // Sync the new audio to the same position
      const a = activeAudio();
      const sync = () => {
        try { a.currentTime = Math.min(t, (a.duration || t)); } catch { /* ignore */ }
        if (wasPlaying) {
          pauseSiteAudio();
          a.play().catch(() => { /* ignore */ });
        }
        refreshTime();
      };
      if (a.readyState >= 1) {
        sync();
      } else {
        a.addEventListener('loadedmetadata', sync, { once: true });
        a.load();
      }
      versionBtns.forEach((b) => {
        const isActive = b.dataset.version === v;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', String(isActive));
      });
    }

    // Wire version buttons
    for (const btn of versionBtns) {
      btn.addEventListener('click', () => {
        const v = btn.dataset.version as Version | undefined;
        if (v) setActive(v);
      });
    }

    // Wire play button
    playBtn.addEventListener('click', () => {
      if (activeAudio().paused) {
        play();
      } else {
        pause();
      }
    });

    // Wire each audio's events
    for (const v of ['r1', 'r7'] as Version[]) {
      const a = audios[v] as HTMLAudioElement;
      a.addEventListener('play', () => {
        if (v === active) setPlayingClass(true);
      });
      a.addEventListener('pause', () => {
        if (v === active) setPlayingClass(false);
      });
      a.addEventListener('ended', () => {
        if (v === active) {
          setPlayingClass(false);
          a.currentTime = 0;
          refreshTime();
        }
      });
      a.addEventListener('timeupdate', () => {
        if (v === active) refreshTime();
      });
      a.addEventListener('loadedmetadata', () => {
        if (v === active) refreshTime();
      });
    }

    // Scrub
    const seek = (clientX: number) => {
      const rect = scrub.getBoundingClientRect();
      const pct = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
      const a = activeAudio();
      if (Number.isFinite(a.duration)) {
        a.currentTime = pct * a.duration;
        // Keep the inactive one in sync too so flipping is instant
        const o = otherAudio();
        if (Number.isFinite(o.duration)) {
          o.currentTime = Math.min(pct * o.duration, o.duration);
        }
      }
    };

    scrub.addEventListener('pointerdown', (e) => {
      (e.target as HTMLElement).setPointerCapture?.(e.pointerId);
      seek(e.clientX);
      const move = (ev: PointerEvent) => seek(ev.clientX);
      const up = () => {
        scrub.removeEventListener('pointermove', move);
        scrub.removeEventListener('pointerup', up);
      };
      scrub.addEventListener('pointermove', move);
      scrub.addEventListener('pointerup', up);
    });

    scrub.addEventListener('keydown', (e) => {
      const a = activeAudio();
      if (!Number.isFinite(a.duration)) return;
      if (e.key === 'ArrowLeft') a.currentTime = Math.max(0, a.currentTime - 5);
      else if (e.key === 'ArrowRight') a.currentTime = Math.min(a.duration, a.currentTime + 5);
    });

    // Stop on global stop signal
    document.addEventListener('hp:stop-all', () => {
      const a = activeAudio();
      // Don't stop ourselves if WE just emitted the signal — but that's safe here
      // because we only emit it before calling .play(), which will trigger this listener
      // synchronously. We guard by checking if we're already paused.
      if (!a.paused) {
        // Skip if we're the one playing — handled by pauseSiteAudio guard
      }
    });

    // Pause this player when any OTHER track audio starts
    document.querySelectorAll<HTMLAudioElement>('audio[data-track-id]').forEach((other) => {
      other.addEventListener('play', () => {
        for (const v of ['r1', 'r7'] as Version[]) {
          const a = audios[v] as HTMLAudioElement;
          if (!a.paused) a.pause();
        }
      });
    });

    // Init time display
    refreshTime();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', wireBattle);
  } else {
    wireBattle();
  }
</script>
