---
import AudioPlayer from './AudioPlayer.astro';
import Spectrogram from './Spectrogram.astro';
import type { PythonTrack } from '../data/album';

interface Props {
  track: PythonTrack;
  hueShift?: number;
}

const { track, hueShift = 0 } = Astro.props;
---

<div class={`track ${track.version ? `track--versioned track--${track.version.tone}` : ''}`} id={`track-${track.id}`}>
  <div class="track-number-row">
    <div class="track-number">{track.number}</div>
    {track.version && (
      <a class={`track-version track-version--${track.version.tone}`} href={track.version.battleHref ?? '#battle'}>
        <span class="track-version-badge">{track.version.badge}</span>
        <span class="track-version-tag">{track.version.tag}</span>
      </a>
    )}
  </div>
  <div class="track-title">{track.title}</div>
  <div class="track-meta">{track.meta}</div>
  {
    track.tags.map((t) => (
      <span class={`track-tag ${t.variant ?? ''}`}>{t.label}</span>
    ))
  }
  <p class="track-description">{track.description}</p>

  <AudioPlayer src={track.audio} label={track.title} trackId={track.id} hueShift={hueShift} />

  <Spectrogram src={track.spectrogram} alt={track.spectrogramAlt} trackTitle={track.title} />
</div>

<style>
  .track-number-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .track-number-row .track-number {
    margin-bottom: 0;
  }
  .track-version {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.22rem 0.55rem 0.22rem 0.32rem;
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid transparent;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .track-version-badge {
    display: inline-grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.04em;
  }
  .track-version-tag { color: rgba(228, 224, 212, 0.65); }

  .track-version--r1 {
    background: rgba(107, 63, 160, 0.08);
    border-color: rgba(107, 63, 160, 0.35);
  }
  .track-version--r1 .track-version-badge {
    background: rgba(107, 63, 160, 0.25);
    color: var(--cream);
    border: 1px solid rgba(199, 75, 143, 0.45);
  }

  .track-version--r7 {
    background: linear-gradient(90deg, rgba(199, 75, 143, 0.1), rgba(93, 169, 232, 0.12));
    border-color: rgba(199, 75, 143, 0.4);
  }
  .track-version--r7 .track-version-badge {
    background: linear-gradient(135deg, var(--magenta), #5da9e8);
    color: var(--white);
    border: 1px solid rgba(240, 192, 64, 0.35);
    box-shadow: 0 0 12px rgba(199, 75, 143, 0.35);
  }

  .track-version:hover {
    transform: translateY(-1px);
    border-color: rgba(240, 192, 64, 0.55);
  }

  .track--versioned {
    margin-bottom: 4rem;
  }
  .track--r7 {
    padding-top: 0.4rem;
    border-top: 1px dashed rgba(199, 75, 143, 0.18);
    margin-top: -2rem;
    padding-left: 0;
  }
</style>
