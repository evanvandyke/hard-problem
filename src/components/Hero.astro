---
import { albumMeta } from '../data/album';
---

<div class="hero hero--art">
  <div class="hero-grain"></div>

  <h1 class="sr-only">{albumMeta.artist} — {albumMeta.title}</h1>

  <figure class="cover-wrap">
    <div class="cover-glow"></div>
    <img
      class="cover-img"
      src="/media/artwork/cover-1600.jpg"
      srcset="/media/artwork/cover-1200.jpg 1200w, /media/artwork/cover-1600.jpg 1600w"
      sizes="(max-width: 900px) 86vw, min(640px, 70vh)"
      alt={`${albumMeta.title} album cover`}
      width="1600"
      height="1600"
      fetchpriority="high"
    />
  </figure>

  <div class="hero-meta">
    <div class="hero-meta-line">
      <span>HARD PROBLEM</span>
      <span class="dot">·</span>
      <span>APRIL 2026</span>
      <span class="dot">·</span>
      <span>LISTEN BELOW</span>
    </div>
  </div>

  <div class="scroll-indicator">SCROLL ↓</div>
</div>

<style>
  .hero--art {
    justify-content: center;
    gap: 2rem;
    padding: 5rem 2rem 4rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .cover-wrap {
    position: relative;
    width: min(86vw, 640px, 72vh);
    aspect-ratio: 1 / 1;
    margin: 0;
    opacity: 0;
    animation: fadeUp 1.8s ease 0.3s forwards;
  }

  .cover-glow {
    position: absolute;
    inset: -12%;
    background:
      radial-gradient(circle at 30% 50%, rgba(107, 63, 160, 0.35) 0%, transparent 55%),
      radial-gradient(circle at 70% 50%, rgba(232, 131, 58, 0.28) 0%, transparent 55%),
      radial-gradient(circle at 50% 50%, rgba(240, 192, 64, 0.22) 0%, transparent 35%);
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
    opacity: 0.9;
  }

  .cover-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 6px;
    box-shadow:
      0 30px 60px -20px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(199, 75, 143, 0.2),
      0 0 40px -8px rgba(199, 75, 143, 0.25);
    object-fit: cover;
  }

  .hero-meta {
    position: relative;
    z-index: 2;
    opacity: 0;
    animation: fadeUp 1.8s ease 1.1s forwards;
  }

  .hero-meta-line {
    font-family: var(--mono);
    font-size: clamp(0.6rem, 1.1vw, 0.75rem);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(232, 131, 58, 0.75);
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-meta-line .dot {
    color: rgba(107, 63, 160, 0.8);
  }

  .hero .scroll-indicator {
    animation-delay: 2s, 3.5s;
  }
</style>
